<!-- ===================== CAPABILITIES: the value, in four moves ===================== -->
<section id="capabilities" class="py-16 md:py-20 bg-white text-gray-900 border-b border-gray-100">
  <div class="container mx-auto px-6">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">What your assistant can do here</h2>
      <p class="text-lg text-gray-600">
        <span class="font-semibold text-gray-900">Connect once, then ask in plain English.</span>
        The server exposes tools for the whole evaluation &mdash; from first look to first contact.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 hover:border-blue-200 hover:shadow-md transition flex flex-col">
        <i class="fas fa-scale-balanced text-2xl text-blue-600 mb-3"></i>
        <h3 class="font-semibold mb-2">Assess my fit</h3>
        <p class="text-sm text-gray-600 mb-4">Paste your job description and get an honest read on where I'm strong and where I'm not, scored against my real experience.</p>
        <p class="text-xs text-gray-500 italic mt-auto">&ldquo;Is Jake a good fit for this role? [paste job description]&rdquo;</p>
      </div>
      <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 hover:border-blue-200 hover:shadow-md transition flex flex-col">
        <i class="fas fa-clipboard-question text-2xl text-blue-600 mb-3"></i>
        <h3 class="font-semibold mb-2">Build the interview</h3>
        <p class="text-sm text-gray-600 mb-4">Generate phone screens, technical deep-dives, system design sessions, or behavioral questions tailored to my background and your focus areas.</p>
        <p class="text-xs text-gray-500 italic mt-auto">&ldquo;Create a phone screen for Jake focused on Kubernetes and API design.&rdquo;</p>
      </div>
      <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 hover:border-blue-200 hover:shadow-md transition flex flex-col">
        <i class="fas fa-file-lines text-2xl text-blue-600 mb-3"></i>
        <h3 class="font-semibold mb-2">Pull the source material</h3>
        <p class="text-sm text-gray-600 mb-4">My resume, GitHub, LinkedIn, and website content, served as structured resources your assistant reads directly &mdash; always current.</p>
        <p class="text-xs text-gray-500 italic mt-auto">&ldquo;Summarize Jake's career highlights.&rdquo;</p>
      </div>
      <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 hover:border-blue-200 hover:shadow-md transition flex flex-col">
        <i class="fas fa-paper-plane text-2xl text-blue-600 mb-3"></i>
        <h3 class="font-semibold mb-2">Reach out</h3>
        <p class="text-sm text-gray-600 mb-4">Looks like a match? Your assistant can email me directly from the conversation &mdash; you review it, the server sends it.</p>
        <p class="text-xs text-gray-500 italic mt-auto">&ldquo;Draft and send Jake an email about our staff platform engineer role.&rdquo;</p>
      </div>
    </div>
  </div>
</section>
