<!-- No-MCP fallback: the resume as plain text, one click to copy.
     resumeText is generated at boot from jakegaylor.com/resume.json
     (see src/resumeMarkdown.ts), so it tracks the canonical resume. -->
<div id="quick-resume" class="bg-white rounded-xl border border-gray-100 p-6 scroll-mt-6">
    <h3 class="font-semibold mb-1">No MCP client? Copy this instead</h3>
    <p class="text-sm text-gray-600 mb-4">Paste the text below into any AI assistant to give it my full background &mdash; no tools or special connections needed. Also available at <a href="/llms.txt" class="text-blue-600 hover:underline" target="_blank" rel="noopener"><code>ai.jakegaylor.com/llms.txt</code></a>.</p>
    <div class="relative">
        <pre id="resume-for-llms" class="overflow-x-auto text-sm bg-gray-900 text-gray-100 p-4 rounded-md whitespace-pre-wrap max-h-96 overflow-y-auto">{{ resumeText }}</pre>
        <button class="copy-btn absolute top-2 right-2 text-sm bg-gray-700 hover:bg-gray-600 text-white rounded px-2 py-1" data-copy-target="resume-for-llms" data-cta="copy-quick-resume">Copy</button>
    </div>
</div>
