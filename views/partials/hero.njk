<!-- ===================== HERO: what this is and why you'd use it ===================== -->
<header class="relative overflow-hidden bg-gradient-to-br from-blue-700 via-blue-800 to-slate-900 text-white">
  <div class="container mx-auto px-6 pt-8 pb-16 md:pb-24">
    <nav class="flex items-center justify-between text-sm mb-12 md:mb-16">
      <a href="https://jakegaylor.com" data-cta="hero-home" class="text-blue-100 hover:text-white transition-colors">
        <i class="fas fa-arrow-left mr-2"></i>jakegaylor.com
      </a>
      <div class="flex items-center gap-6">
        <a href="#capabilities" data-cta="hero-nav-capabilities" class="text-blue-100 hover:text-white transition-colors hidden sm:inline">What it does</a>
        <a href="#connect" data-cta="hero-nav-connect" class="text-blue-100 hover:text-white transition-colors">Connect</a>
        <a href="#under-the-hood" data-cta="hero-nav-under-the-hood" class="text-blue-100 hover:text-white transition-colors hidden sm:inline">Under the hood</a>
      </div>
    </nav>

    <div class="max-w-3xl">
      <p class="text-blue-200 font-semibold tracking-widest uppercase text-sm mb-5">
        A live MCP server for AI assistants
      </p>
      <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">
        Teach your AI
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-200 to-white">about {{ name }}.</span>
      </h1>
      <p class="text-xl md:text-2xl text-blue-100 mb-8 max-w-2xl">
        Point your assistant at this server and it can read my resume, score my fit
        against your job description, build the interview, and even email me &mdash;
        no copy-pasting, no stale PDFs.
      </p>

      <div class="inline-flex items-center gap-3 bg-white/10 border border-white/20 rounded-md px-4 py-3 mb-10 max-w-full">
        <i class="fas fa-plug text-blue-200"></i>
        <code id="mcp-endpoint" class="text-blue-50 text-sm md:text-base overflow-x-auto whitespace-nowrap">https://ai.jakegaylor.com/mcp</code>
        <button class="copy-btn shrink-0 text-sm bg-white/20 hover:bg-white/30 rounded px-2.5 py-1 transition-colors" data-copy-target="mcp-endpoint" data-cta="hero-copy-endpoint">Copy</button>
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#connect" data-cta="hero-connect" class="inline-flex items-center justify-center px-7 py-3.5 text-base font-semibold rounded-md text-blue-800 bg-white hover:bg-blue-50 transition-colors shadow-lg">
          <i class="fas fa-bolt mr-2"></i>
          Connect your assistant
        </a>
        <a href="#quick-resume" data-cta="hero-quick-resume" class="inline-flex items-center justify-center px-7 py-3.5 text-base font-medium rounded-md text-white border border-white/40 hover:bg-white/10 transition-colors">
          <i class="fas fa-copy mr-2"></i>
          No MCP? Copy my resume instead
        </a>
      </div>
    </div>
  </div>
</header>
