<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    {% include "partials/head.njk" %}
</head>
<body id="top" class="bg-gray-50 text-gray-900 antialiased min-h-screen flex flex-col">
    {% import "partials/collapse.njk" as comp %}

    <main class="flex-grow">
        {% include "partials/hero.njk" %}
        {% include "partials/capabilities.njk" %}
        {% include "partials/connect.njk" %}
        {% include "partials/under-the-hood.njk" %}
        {% include "partials/cta.njk" %}
    </main>

    {% include "partials/footer.njk" %}

    <script>
        // Copy buttons: copy the nearest [data-copy] target (or previous sibling's text).
        document.querySelectorAll('.copy-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const targetId = btn.getAttribute('data-copy-target');
                const source = targetId ? document.getElementById(targetId) : btn.previousElementSibling;
                navigator.clipboard.writeText(source.textContent.trim()).then(() => {
                    const original = btn.innerHTML;
                    btn.innerHTML = 'Copied!';
                    setTimeout(() => btn.innerHTML = original, 2000);
                });
            });
        });

        // CTA click tracking, same signal layer as jakegaylor.com.
        if (typeof posthog !== 'undefined') {
            document.querySelectorAll('[data-cta]').forEach(el => {
                el.addEventListener('click', () => {
                    posthog.capture('cta_click', { cta: el.getAttribute('data-cta') });
                });
            });
        }
    </script>
</body>
</html>
